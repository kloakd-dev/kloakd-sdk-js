{
  "name": "kloakd-sdk",
  "version": "0.1.0",
  "description": "The official TypeScript/JavaScript SDK for the KLOAKD API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "jest --coverage",
    "test:ci": "jest --coverage --ci",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "kloakd",
    "web-scraping",
    "api",
    "sdk",
    "automation"
  ],
  "author": "KLOAKD <sdk@kloakd.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kloakd/kloakd-sdk-js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "jest": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
